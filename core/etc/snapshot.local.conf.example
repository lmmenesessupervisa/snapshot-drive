# ===========================================================
# snapshot-V3 — override local por instalación
# -----------------------------------------------------------
# install.sh ya crea /etc/snapshot-v3/snapshot.local.conf con permisos 0600
# desde esta plantilla si no existe. Edítalo con sudo y rellena los valores.
#
#   sudo nano /etc/snapshot-v3/snapshot.local.conf
#   sudo systemctl restart snapshot-backend
#
# Vive fuera de /opt/snapshot-V3/ para sobrevivir a upgrades (el rsync
# --delete de install.sh no lo toca). Sus valores sobreescriben a los
# de snapshot.conf al ser cargado por common.sh.
# ===========================================================

# Credenciales del OAuth Client (Device Flow) creado en Google Cloud Console
# tipo "TVs and Limited Input devices".
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- SMTP para notificaciones por email -------------------------------------
# snapctl envía un correo tras cada operación (create, reconcile, prune) si
# estas variables están completas. Deja SMTP_HOST vacío para desactivar.
# Si usas Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587 y SMTP_PASSWORD
# debe ser una App Password (16 chars), NO la contraseña real de la cuenta.
#
# ATENCIÓN: estas credenciales quedan en claro (con permisos 600) en el
# servidor del cliente. Si no confías plenamente en los administradores del
# servidor, usa una cuenta SMTP dedicada sin otros privilegios, o mueve las
# notificaciones a la máquina ops centralizada.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
NOTIFY_EMAIL=""

# --- Vista de auditoría agregada (solo instalación ops) ---------------------
# /audit muestra el estado de TODOS los clientes leyendo el shared Drive.
# Ponlo a 1 ÚNICAMENTE en tu máquina ops, nunca en un servidor de cliente
# (los clientes no deben poder ver a otros clientes).
SNAPSHOT_AUDIT_VIEWER="0"
# Contraseña para acceder a /audit (el único login de la vista).
AUDIT_PASSWORD=""
# Carpeta raíz dentro del shared Drive donde están los subfolders por host
# (si cada cliente sube a 'snapshots/<hostname>/', déjalo en 'snapshots').
AUDIT_REMOTE_PATH="snapshots"

# --- Backup mensual cold-storage (archive) ---------------------------------
# snapctl archive genera un .tar.zst (opcionalmente encriptado) y lo sube a
# una ruta taxonómica dentro del shared Drive:
#   BACKUP_PROYECTO/BACKUP_ENTORNO/BACKUP_PAIS/os/linux/BACKUP_NOMBRE/
#     YYYY/MM/DD/servidor_<nombre>_<YYYYMMDD_HHMMSS>.tar.zst[.enc]
#
# Todo configurable desde el panel (Ajustes → Backup mensual). Aquí abajo el
# ejemplo de los valores esperados.
#
# Valores válidos para proyecto:  superaccess-uno | superaccess-dos |
#                                 basculas | proyectos-especiales | orus
# Valores para entorno:           cloud | local
# Valores para pais:              colombia | peru | costa-rica | panama
# BACKUP_NOMBRE default: $(hostname -s)
BACKUP_PROYECTO=""
BACKUP_ENTORNO=""
BACKUP_PAIS=""
BACKUP_NOMBRE=""

# Password de encriptación. Si está vacía, los archivos se suben en claro
# (.tar.zst sin .enc). Si se pone, encripta con AES-256-CBC + PBKDF2 100k.
# ATENCIÓN: si la cambias, los archivos viejos siguen necesitando la
# password vieja para descifrarlos — guarda un registro.
ARCHIVE_PASSWORD=""

# Retención del archive-prune (meses). Por default conserva últimos 12.
ARCHIVE_KEEP_MONTHS="12"

# --- Tuning rclone (opcional) -----------------------------------------------
# Perfil automático según el tipo de Drive detectado en rclone.conf:
#   auto (default) — "shared" si rclone.conf tiene team_drive, "personal" si no
#   personal       — conservador (~10 qps), seguro para Drive personal
#   shared         — agresivo (~100 qps), solo en Shared Drives
#
# Con auto-detección normalmente no hace falta tocar nada. Overrides manuales
# (si necesitas tunear todavía más o menos):
# RCLONE_PROFILE="auto"
# RCLONE_TPSLIMIT="30"
# RCLONE_TRANSFERS="8"

# (Opcional) Webhook para POST JSON en cada operación:
# NOTIFY_WEBHOOK="https://hooks.example.com/xyz"
# RCLONE_BWLIMIT="8M"

# Master key for encrypting MFA secrets at rest. 64 hex chars (32 bytes).
# Auto-generated by install.sh if missing. Keep it safe — losing it
# invalidates all enrolled TOTP secrets (users must re-enroll via
# backup codes or 'snapctl admin reset-mfa').
SECRET_KEY=""

# --- Sub-D: Alertas (solo aplica en MODE=central) -------------------------
# Threshold para "cliente sin reportar":
ALERTS_NO_HEARTBEAT_HOURS="48"
# Threshold % shrink en totals para "backup borrado":
ALERTS_SHRINK_PCT="20"
# Destinatario de notificaciones — vacío = sin email:
ALERTS_EMAIL=""
# Webhook POST JSON opcional (Slack/Discord/PagerDuty webhook URL):
ALERTS_WEBHOOK=""

# --- Sub-E: DB backups ---------------------------------------------------
# Lista space-separated de "engine:dbname" (engines: postgres, mysql, mongo).
# Vacío = no DB backups, no se activa el timer.
DB_BACKUP_TARGETS=""

# Postgres connection. Si DB_PG_HOST está vacío, pg_dump usa socket Unix.
DB_PG_HOST=""
DB_PG_PORT="5432"
DB_PG_USER=""
DB_PG_PASSWORD=""

# MySQL / MariaDB:
DB_MYSQL_HOST=""
DB_MYSQL_PORT="3306"
DB_MYSQL_USER=""
DB_MYSQL_PASSWORD=""

# MongoDB URI completo (incluye auth):
# mongodb://user:pass@host:27017/?authSource=admin
DB_MONGO_URI=""

# --- Sub-F: Cifrado opcional con age (alternativa a ARCHIVE_PASSWORD) ----
# Si está seteado, age toma precedencia sobre ARCHIVE_PASSWORD para los
# backups nuevos (los viejos siguen restauraables con su modo original).
# Generá un keypair con: sudo snapctl crypto-keygen
# Soporta 2+ recipients separados por espacios:
#   ARCHIVE_AGE_RECIPIENTS="age1abc... age1xyz..."
ARCHIVE_AGE_RECIPIENTS=""

# Path al archivo de identidad (privada). Solo se usa para restore.
# Mode 0600. NO debe estar seteado en hosts de producción — solo
# temporalmente cuando vas a restaurar un .age.
ARCHIVE_AGE_IDENTITY_FILE=""
