# ===========================================================
# snapshot-V3 — override local por instalación
# -----------------------------------------------------------
# Copia este archivo a snapshot.local.conf y rellena los valores:
#
#   sudo cp core/etc/snapshot.local.conf.example \
#           core/etc/snapshot.local.conf
#   sudo chmod 600 core/etc/snapshot.local.conf
#
# snapshot.local.conf está en .gitignore — no se sube al repo.
# Sus valores sobreescriben a los de snapshot.conf.
# ===========================================================

# Credenciales del OAuth Client (Device Flow) creado en Google Cloud Console
# tipo "TVs and Limited Input devices".
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# (Opcional) Overrides por sitio — descomentar según haga falta:
# NOTIFY_EMAIL="ops@ejemplo.com"
# NOTIFY_WEBHOOK="https://hooks.example.com/xyz"
# RCLONE_BWLIMIT="8M"
