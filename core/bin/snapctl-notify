#!/usr/bin/env python3
"""snapctl-notify — envía un correo SMTP con el estado de una operación.

Se invoca desde common.sh tras cada create/reconcile/prune. Lee la config
SMTP del entorno (que common.sh exporta tras sourcear snapshot.conf y
snapshot.local.conf) y manda un HTML sencillo pero profesional, con el
mismo cuerpo de texto plano como fallback.

Uso:
    echo "cuerpo del mensaje" | snapctl-notify "Asunto"

Variables de entorno esperadas:
    SMTP_HOST SMTP_PORT SMTP_USER SMTP_PASSWORD SMTP_FROM NOTIFY_EMAIL
    SNAPSHOT_NOTIFY_STATUS   ok | fail | info  (pinta el banner del correo)
    SNAPSHOT_NOTIFY_META     JSON opcional {tag, duration, size, snapshot_id}

Sale con rc=0 si se envió (o si SMTP no está configurado y por lo tanto
la notificación es un no-op deliberado), rc!=0 solo si los settings
estaban completos pero el envío explotó. Esto permite que common.sh
llame al binario siempre y no falle cuando el cliente aún no ha
configurado SMTP.
"""
from __future__ import annotations

import json
import os
import smtplib
import socket
import sys
from datetime import datetime, timezone
from email.mime.multipart import MIMEMultipart
from email.mime.text import MIMEText


STATUS_STYLES = {
    # color_primary, color_soft, label, icon_svg_path (inlined), preheader_verb
    "ok": (
        "#059669", "#d1fae5", "Backup completado",
        "M5 13l4 4L19 7",  # checkmark
        "exitoso",
    ),
    "fail": (
        "#dc2626", "#fee2e2", "Backup con errores",
        "M18 6L6 18M6 6l12 12",  # x
        "con errores",
    ),
    "info": (
        "#2563eb", "#dbeafe", "Notificación del sistema",
        "M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 1 1 0 20 10 10 0 0 1 0-20z",  # info
        "informativo",
    ),
}

# Mapa de nombres humanos — evitar tecnicismos crudos en el correo.
TARGET_LABELS = {
    "drive": "Google Drive",
    "local": "Buffer local (pendiente de subir)",
}
OP_LABELS = {
    "create": "Crear snapshot",
    "reconcile": "Reconciliar con Drive",
    "prune": "Aplicar retención",
    "init": "Inicializar repositorio",
}


def _env(name: str, default: str = "") -> str:
    return (os.environ.get(name) or default).strip()


def _human_bytes(n: int) -> str:
    n = float(n)
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if n < 1024 or unit == "TB":
            return f"{n:,.1f} {unit}" if unit != "B" else f"{int(n):,} B"
        n /= 1024
    return f"{n} B"


def _human_duration(s: int) -> str:
    s = max(0, int(s))
    if s < 60:
        return f"{s} s"
    m, ss = divmod(s, 60)
    if m < 60:
        return f"{m} min {ss:02d} s"
    h, mm = divmod(m, 60)
    return f"{h} h {mm:02d} min"


def _detail_rows(meta: dict) -> list[tuple[str, str, bool]]:
    """Devuelve [(label, value_html, is_mono), ...] ordenado."""
    out: list[tuple[str, str, bool]] = []
    if meta.get("tag"):
        out.append(("Etiqueta", f"#{meta['tag']}", True))
    if meta.get("duration_s") is not None:
        out.append(("Duración", _human_duration(meta["duration_s"]), False))
    if meta.get("size_bytes") is not None:
        out.append(("Tamaño", _human_bytes(meta["size_bytes"]), False))
    if meta.get("snapshot_id"):
        out.append(("Snapshot ID", meta["snapshot_id"][:16], True))
    if meta.get("target"):
        out.append(("Destino", TARGET_LABELS.get(meta["target"], meta["target"]), False))
    if meta.get("moved") is not None:
        out.append(("Snapshots movidos", str(meta["moved"]), False))
    return out


def _build_preheader(host: str, subject: str, meta: dict) -> str:
    """Texto que Gmail/Outlook muestran como snippet junto al asunto."""
    bits = [host]
    if meta.get("duration_s") is not None:
        bits.append(_human_duration(meta["duration_s"]))
    if meta.get("tag"):
        bits.append(f"tag #{meta['tag']}")
    if meta.get("target"):
        bits.append(TARGET_LABELS.get(meta["target"], meta["target"]))
    return " · ".join(bits)


def build_html(subject: str, body: str, host: str, status: str, meta: dict) -> str:
    primary, soft, label, icon_path, _verb = STATUS_STYLES.get(status, STATUS_STYLES["info"])
    now_utc = datetime.now(timezone.utc)
    now_display = now_utc.strftime("%d %b %Y · %H:%M UTC")
    preheader = _build_preheader(host, subject, meta)

    # Detalle como filas de tabla
    detail_items = _detail_rows(meta)
    detail_rows_html = ""
    if detail_items:
        row_strs = []
        for i, (lbl, val, is_mono) in enumerate(detail_items):
            is_last = i == len(detail_items) - 1
            border = "" if is_last else "border-bottom:1px solid #f1f5f9;"
            mono = "font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;" if is_mono else ""
            row_strs.append(
                f'<tr>'
                f'<td style="padding:11px 0;{border}font-size:12px;color:#64748b;letter-spacing:0.01em;width:160px;vertical-align:top">{lbl}</td>'
                f'<td style="padding:11px 0;{border}font-size:13px;color:#0f172a;{mono}font-weight:500;vertical-align:top;word-break:break-word">{val}</td>'
                f'</tr>'
            )
        detail_rows_html = f"""
        <tr>
          <td style="padding:24px 32px 4px 32px">
            <div style="font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#94a3b8;font-weight:700;margin-bottom:4px">Detalles</div>
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="border-collapse:collapse">
              {''.join(row_strs)}
            </table>
          </td>
        </tr>"""

    # Callout de error (solo si aplica)
    error_html = ""
    if meta.get("error"):
        error_html = f"""
        <tr>
          <td style="padding:8px 32px 4px 32px">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background:#fef2f2;border:1px solid #fecaca;border-radius:8px">
              <tr>
                <td style="padding:14px 16px">
                  <div style="font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:#b91c1c;font-weight:700;margin-bottom:4px">Error reportado</div>
                  <div style="font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:12px;color:#7f1d1d;line-height:1.5;word-break:break-word">{meta['error']}</div>
                </td>
              </tr>
            </table>
          </td>
        </tr>"""

    # Body log — solo mostramos si aporta algo más allá de los detalles
    log_html = ""
    if body and body != "(sin detalle)":
        log_html = f"""
        <tr>
          <td style="padding:16px 32px 4px 32px">
            <div style="font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#94a3b8;font-weight:700;margin-bottom:8px">Resumen</div>
            <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:12px 14px;font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:12px;line-height:1.6;color:#475569;white-space:pre-wrap;word-break:break-word">{body}</div>
          </td>
        </tr>"""

    return f"""<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="color-scheme" content="light">
<meta name="supported-color-schemes" content="light">
<title>snapshot-V3</title>
</head>
<body style="margin:0;padding:0;background:#f1f5f9;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale">

<div style="display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#f1f5f9">{preheader}</div>

<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background:#f1f5f9;padding:32px 16px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Helvetica Neue',Arial,sans-serif">
  <tr>
    <td align="center">

      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" style="max-width:600px;width:100%;background:#ffffff;border-radius:14px;overflow:hidden;box-shadow:0 1px 2px rgba(15,23,42,0.04),0 8px 24px rgba(15,23,42,0.08)">

        <tr>
          <td style="background:{primary};height:4px;line-height:4px;font-size:0">&nbsp;</td>
        </tr>

        <tr>
          <td style="padding:28px 32px 4px 32px">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0">
              <tr>
                <td style="padding-right:12px;vertical-align:middle">
                  <div style="display:inline-block;width:36px;height:36px;line-height:34px;text-align:center;background:#0f172a;color:#ffffff;border-radius:9px;font-weight:700;font-size:15px;letter-spacing:-0.02em">S</div>
                </td>
                <td style="vertical-align:middle">
                  <div style="font-size:13px;font-weight:600;color:#0f172a;letter-spacing:-0.01em">snapshot-V3</div>
                  <div style="font-size:11px;color:#94a3b8;margin-top:1px">Gestión automatizada de backups</div>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <tr>
          <td style="padding:24px 32px 8px 32px">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0">
              <tr>
                <td style="vertical-align:middle;padding-right:14px">
                  <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                    <tr>
                      <td style="width:44px;height:44px;background:{soft};border-radius:11px;text-align:center;vertical-align:middle">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="{primary}" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle"><path d="{icon_path}"/></svg>
                      </td>
                    </tr>
                  </table>
                </td>
                <td style="vertical-align:middle">
                  <div style="font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:{primary};font-weight:700">{label}</div>
                  <div style="font-size:20px;font-weight:600;color:#0f172a;margin-top:4px;line-height:1.25;letter-spacing:-0.01em">{subject}</div>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <tr>
          <td style="padding:12px 32px 0 32px">
            <div style="font-size:13px;color:#475569;line-height:1.5">
              Cliente <strong style="color:#0f172a;font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-weight:600">{host}</strong>
            </div>
          </td>
        </tr>

        {error_html}
        {detail_rows_html}
        {log_html}

        <tr>
          <td style="padding:28px 32px 28px 32px">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="border-top:1px solid #f1f5f9;padding-top:20px">
              <tr>
                <td style="padding-top:20px;vertical-align:top">
                  <div style="font-size:11px;color:#64748b;font-weight:600">snapshot-V3</div>
                  <div style="font-size:11px;color:#94a3b8;margin-top:3px;font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace">{now_display}</div>
                </td>
                <td style="padding-top:20px;vertical-align:top;text-align:right">
                  <div style="font-size:11px;color:#94a3b8">Notificación automática</div>
                  <div style="font-size:11px;color:#cbd5e1;margin-top:3px">No es necesario responder</div>
                </td>
              </tr>
            </table>
          </td>
        </tr>

      </table>

      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" style="max-width:600px;width:100%;margin-top:16px">
        <tr>
          <td align="center" style="font-size:11px;color:#94a3b8;padding:0 24px;line-height:1.6">
            Este correo lo genera snapshot-V3 tras cada operación del motor de backups.<br>
            Para soporte: <a href="mailto:soporte@superaccess.co" style="color:#64748b;text-decoration:underline">soporte@superaccess.co</a>
          </td>
        </tr>
      </table>

    </td>
  </tr>
</table>

</body>
</html>"""


def build_plain(subject: str, body: str, host: str, status: str, meta: dict) -> str:
    """Versión plain text — se adjunta como fallback."""
    _primary, _soft, label, _ico, _verb = STATUS_STYLES.get(status, STATUS_STYLES["info"])
    lines = [
        f"snapshot-V3 — {label}",
        "=" * 48,
        "",
        subject,
        f"Cliente: {host}",
        "",
    ]
    for lbl, val, _mono in _detail_rows(meta):
        lines.append(f"  {lbl:.<20} {val}")
    if meta.get("error"):
        lines += ["", "ERROR:", f"  {meta['error']}"]
    if body and body != "(sin detalle)":
        lines += ["", "Resumen:", body]
    lines += ["", "-" * 48,
              f"Notificación automática · {datetime.now(timezone.utc).strftime('%d %b %Y · %H:%M UTC')}",
              "soporte@superaccess.co"]
    return "\n".join(lines)


def main() -> int:
    if len(sys.argv) < 2:
        print("uso: snapctl-notify SUBJECT  (cuerpo por stdin)", file=sys.stderr)
        return 2

    host = _env("SMTP_HOST")
    user = _env("SMTP_USER")
    password = _env("SMTP_PASSWORD").replace(" ", "")
    sender = _env("SMTP_FROM") or user
    to_addr = _env("NOTIFY_EMAIL")

    # Si SMTP no está configurado, salir OK — es un no-op deliberado, no un error.
    if not all([host, user, password, sender, to_addr]):
        return 0

    subject_raw = sys.argv[1]
    body = sys.stdin.read().strip() or "(sin detalle)"
    hostname = _env("HOSTNAME") or socket.gethostname().split(".")[0]
    status = _env("SNAPSHOT_NOTIFY_STATUS", "info").lower()

    try:
        meta = json.loads(_env("SNAPSHOT_NOTIFY_META") or "{}")
    except json.JSONDecodeError:
        meta = {}

    subject = f"[snapshot-V3] {subject_raw}"
    html = build_html(subject_raw, body, hostname, status, meta)
    plain = build_plain(subject_raw, body, hostname, status, meta)

    msg = MIMEMultipart("alternative")
    msg["From"] = f"snapshot-V3 <{sender}>"
    msg["To"] = to_addr
    msg["Subject"] = subject
    # Según RFC 2046, el último part en un multipart/alternative es el que
    # los clientes modernos renderizan preferencialmente. Adjuntamos primero
    # el plain-text y después el HTML.
    msg.attach(MIMEText(plain, "plain", "utf-8"))
    msg.attach(MIMEText(html, "html", "utf-8"))

    port = int(_env("SMTP_PORT", "587"))
    try:
        if port == 465:
            smtp = smtplib.SMTP_SSL(host, port, timeout=20)
        else:
            smtp = smtplib.SMTP(host, port, timeout=20)
            smtp.ehlo()
            smtp.starttls()
            smtp.ehlo()
        try:
            smtp.login(user, password)
            smtp.sendmail(sender, [to_addr], msg.as_string())
        finally:
            smtp.quit()
    except Exception as e:
        print(f"SMTP error: {type(e).__name__}: {e}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
